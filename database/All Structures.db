This file includes the structures that are useful for the quick understand for next creation

1:(Insertion of rows)
INSERT INTO timetablec2()
VALUES
(),(),(),(),(),(),(),(),(),(),
(),(),(),(),(),(),(),(),(),(),
(),(),(),(),(),(),(),(),(),(),
(),(),(),(),(),(),(),(),(),(),
(),(),(),(),(),(),(),();          //it indicates no of rows without null


2:(updated the days for all days)
UPDATE timetablec2
SET day = CASE 
    WHEN Sno BETWEEN 1  AND 8  THEN 'Monday'
    WHEN Sno BETWEEN 9  AND 16 THEN 'Tuesday'
    WHEN Sno BETWEEN 17 AND 24 THEN 'Wednesday'
    WHEN Sno BETWEEN 25 AND 32 THEN 'Thursday'
    WHEN Sno BETWEEN 33 AND 40 THEN 'Friday'
    WHEN Sno BETWEEN 41 AND 48 THEN 'Saturday'
END

3: (time insertion for 8 periods)
UPDATE timetablec2
SET start = CASE
WHEN period = 1 THEN '09:00'
WHEN period = 2 THEN '09:50'
WHEN period = 3 THEN '11:00'
WHEN period = 4 THEN '11:50'
WHEN period = 5 THEN '13:30'
WHEN period = 6 THEN '14:20'
WHEN period = 7 THEN '15:10'
WHEN period = 8 THEN '16:10'
END,
end = CASE
WHEN period = 1 THEN '09:50'
WHEN period = 2 THEN '10:40'
WHEN period = 3 THEN '11:50'
WHEN period = 4 THEN '12:40'
WHEN period = 5 THEN '14:20'
WHEN period = 6 THEN '15:10'
WHEN period = 7 THEN '16:10'
WHEN period = 8 THEN '17:00'
END
WHERE Sno > 0;

4:(locating the room numbers for each dayand define period)
UPDATE timetablec2
SET room_no = CASE
WHEN day = '--day--' AND period = 1 THEN '--roo_no--'
WHEN day = '--day--' AND period = 2 THEN '--roo_no--'
WHEN day = '--day--' AND period = 3 THEN '--roo_no--'
WHEN day = '--day--' AND period = 4 THEN '--roo_no--'
WHEN day = '--day--' AND period = 5 THEN '--roo_no--'
WHEN day = '--day--' AND period = 6 THEN '--roo_no--'
WHEN day = '--day--' AND period = 7 THEN '--roo_no--'
WHEN day = '--day--' AND period = 8 THEN '--roo_no--'
ElSE room_no
END
WHERE day = '--day--' AND Sno >1;
