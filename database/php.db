<!-- 
?php

error_reporting(E_ALL);
ini_set('display_errors', 1);

date_default_timezone_set("Asia/Kolkata");

$conn = new mysqli("localhost", "root", "JesuS0108.", "project");

if ($conn->connect_error) {
    die("Connection failed: " . $conn->connect_error);
}

if(isset($_POST['name'])){

    $name = $conn->real_escape_string($_POST['name']);
    $currentTime = date("H:i:s");
    $currentDay = date("l");

    // -------- CHECK NAME EXISTS --------

    $checkName = "SELECT name FROM details WHERE name='$name'";
    $nameResult = $conn->query($checkName);

    if($nameResult->num_rows == 0){
        echo "<h2>No Name Found</h2>";
    }

    else{

        if($currentDay == "Sunday"){
            echo "<h2>Public Holiday</h2>";
        }

        elseif($currentTime < "09:00:00" || $currentTime >= "17:00:00"){
            echo "<h2>College Over</h2>";
        }

        elseif($currentTime >= "10:40:00" && $currentTime < "11:00:00"){
            echo "<h2>Morning Break</h2>";
        }

        elseif($currentTime >= "12:40:00" && $currentTime < "13:30:00"){
            echo "<h2>Lunch Time</h2>";
        }

        elseif($currentTime >= "15:10:00" && $currentTime < "15:20:00"){
            echo "<h2>Evening Break</h2>";
        }

        else{   

            $sql = "
            SELECT d.name, d.student_id, d.branch, d.section,
       t.subject, t.room_no, t.start, t.end

FROM (
    SELECT name, student_id, branch, section FROM civil
    UNION
    SELECT name, student_id, branch, section FROM mech
) d

JOIN timetable t
ON d.branch = t.branch
AND d.section = t.section

WHERE d.name = '$name'
AND t.day = DAYNAME(CURDATE())
AND CURTIME() BETWEEN t.start AND t.end

LIMIT 1
            
            ";
            
            $result = $conn->query($sql);

            if($result && $result->num_rows > 0){

                $row = $result->fetch_assoc();

                $startTime = date("g:i A", strtotime($row['start']));
                $endTime = date("g:i A", strtotime($row['end']));

                echo "<h2>Student Details</h2>";

                echo "Name: ".$row['name']."<br>";
                echo "Student ID: ".$row['student_id']."<br>";
                echo "Branch: ".$row['branch']."<br>";
                echo "Section: ".$row['section']."<br>";
                echo "Subject: ".$row['subject']."<br>";
                echo "Room No: ".$row['room_no']."<br>";
                echo "Timing: ".$startTime." - ".$endTime."<br>";

                if($row['mech_place']){
                    echo "Place: ".$row['mech_place']."<br>";
                    echo "Mobile: ".$row['mech_mobile']."<br>";
                }

                if($row['civil_place']){
                    echo "Place: ".$row['civil_place']."<br>";
                    echo "Mobile: ".$row['civil_mobile']."<br>";
                }

            }

            else{
                echo "<h2>No Class Running Now</h2>";
            }

        }

    }

}

else{
    echo "<h2>No Name Received</h2>";
}

$conn->close();

?> -->
