Created the table of civil students contains the 2,3 and 4th year
inserted the 48 recordes and updating the timetable, giving the day wise subject

UPDATE timetable
SET room_no = CASE
WHEN day = 'monday' AND period_no = 1 THEN 'Online'
WHEN day = 'monday' AND period_no = 2 THEN 'Online'
WHEN day = 'monday' AND period_no = 3 THEN 'Online'
WHEN day = 'monday' AND period_no = 4 THEN 'Online'
WHEN day = 'monday' AND period_no = 5 THEN 'Online'
WHEN day = 'monday' AND period_no = 6 THEN 'Online'
WHEN day = 'monday' AND period_no = 7 THEN 'Online'
WHEN day = 'monday' AND period_no = 8 THEN 'Online'
END
WHERE day = 'monday';


UPDATE timetable
SET room_no = CASE
WHEN day = 'tuesday' AND period_no = 1 THEN 'G101'
WHEN day = 'tuesday' AND period_no = 2 THEN 'G101'
WHEN day = 'tuesday' AND period_no = 3 THEN 'F202'
WHEN day = 'tuesday' AND period_no = 4 THEN 'F202'
WHEN day = 'tuesday' AND period_no = 5 THEN 'E201'
WHEN day = 'tuesday' AND period_no = 6 THEN 'E201'
WHEN day = 'tuesday' AND period_no = 7 THEN 'E201'
WHEN day = 'tuesday' AND period_no = 8 THEN 'E201'
    END
WHERE day = 'tuesday';



