UPDATE timetable
SET room_no = CASE
WHEN Sno = 25  THEN 'E201'
WHEN Sno = 26  THEN 'E201'
WHEN Sno = 27  THEN 'G102'
WHEN Sno = 28  THEN 'G102'
WHEN Sno = 29  THEN 'G102'
WHEN Sno = 30  THEN 'G102'
WHEN Sno = 31  THEN 'G101'
WHEN Sno = 32  THEN 'G101'
    END
WHERE Sno IN (25,26,27,28,29,30,31,32);


